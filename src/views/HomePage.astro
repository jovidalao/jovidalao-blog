---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import ConverloopCard from '../components/ConverloopCard.astro';
import PeeldayCard from '../components/PeeldayCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getUi } from '../i18n';
import '../styles/peelday.css';

const t = getUi(Astro.currentLocale);
---

<!doctype html>
<html lang={Astro.currentLocale}>
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="home-intro">
				<h1>{t.home.greeting}</h1>
				<p class="lead">{t.home.intro}</p>
			</section>
			<section>
				<h2 class="home-section-title">{t.home.appsHeading}</h2>
				<div class="home-app-cards">
					<PeeldayCard />
					<ConverloopCard />
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
