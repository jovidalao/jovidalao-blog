---
import PeeldayLegalDoc from '../components/PeeldayLegalDoc.astro';
import PeeldayLayout from '../layouts/PeeldayLayout.astro';
import { getUi } from '../i18n';

interface Props {
	type: 'privacy' | 'terms';
}

const { type } = Astro.props;
const t = getUi(Astro.currentLocale);
const pageTitle = type === 'privacy' ? t.legal.privacyTitle : t.legal.termsTitle;
const heading = type === 'privacy' ? t.peelday.legal.privacy : t.peelday.legal.terms;
---

<PeeldayLayout title={pageTitle} description={t.peelday.metaDescription} showLegalBar={false}>
	<div class="peelday-legal-page">
		<h1>{heading}</h1>
		<PeeldayLegalDoc type={type} />
	</div>
</PeeldayLayout>
