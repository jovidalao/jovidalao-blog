---
import StickoLegalDoc from '../../../components/StickoLegalDoc.astro';
import StickoLayout from '../../../layouts/StickoLayout.astro';
import { STICKO } from '../../../consts';
import { getUi } from '../../../i18n/ui';

const t = getUi(Astro.currentLocale);
---

<StickoLayout title={`${STICKO.name} — ${STICKO.tagline}`} description={t.sticko.metaDescription}>
	<section class="sticko-hero">
		<div class="sticko-hero-copy">
			<p class="tagline">{STICKO.tagline}</p>
			<h1>{STICKO.name}</h1>
			<p class="subtitle">{t.sticko.heroSubtitle}</p>
			<div class="sticko-cta-row">
				{
					STICKO.appStoreUrl ? (
						<a class="sticko-btn sticko-btn-primary" href={STICKO.appStoreUrl} target="_blank" rel="noopener noreferrer">
							{t.sticko.download}
						</a>
					) : (
						<span class="sticko-btn sticko-btn-muted">{t.sticko.comingSoon}</span>
					)
				}
			</div>
		</div>
		<div class="sticko-hero-visual">
			<div class="sticko-phone-frame">
				<img class="hero-shot" src="/sticko/hero.jpg" alt="Sticko 应用截图" width="296" height="640" loading="eager" />
			</div>
			<img class="sticko-app-icon-float" src="/sticko/app-icon.png" alt="" width="88" height="88" />
		</div>
	</section>

	<section class="sticko-features">
		<h2>{t.sticko.featuresHeading}</h2>
		<div class="sticko-feature-grid">
			{
				t.sticko.features.map((feature) => (
					<article class="sticko-feature-card">
						<h3>{feature.title}</h3>
						<p>{feature.body}</p>
					</article>
				))
			}
		</div>
	</section>
</StickoLayout>
