---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PeeldayLegalBar from '../components/PeeldayLegalBar.astro';
import '../styles/peelday.css';

interface Props {
	title: string;
	description: string;
	showLegalBar?: boolean;
}

const { title, description, showLegalBar = true } = Astro.props;
---

<!doctype html>
<html lang={Astro.currentLocale}>
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main class="peelday-main">
			<slot />
			{showLegalBar && <PeeldayLegalBar />}
		</main>
		<Footer />
	</body>
</html>
