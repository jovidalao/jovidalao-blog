---
import { PEELDAY } from '../consts';
import { getUi, localeBase } from '../i18n';

interface Props {
	href?: string;
}

const { href } = Astro.props;
const base = localeBase(Astro.currentLocale);
const t = getUi(Astro.currentLocale);
const peeldayHref = href ?? `${base}/peelday`;
---

<a class="app-card" href={peeldayHref}>
	<div class="app-card-top">
		<img class="app-card-icon" src="/peelday/app-icon.png" alt="" width="64" height="64" />
		<div class="app-card-meta">
			<span class="app-card-badge">{t.home.peeldayBadge}</span>
			<h3>{t.home.peeldayTitle}</h3>
		</div>
	</div>
	<p class="app-card-desc">{t.home.peeldayDescription}</p>
	<span class="app-card-cta">{t.home.peeldayCta} →</span>
</a>

<style is:global>
	@import '../styles/peelday.css';
</style>
