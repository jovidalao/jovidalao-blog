---
import { getUi, localeBase } from '../i18n';

interface Props {
	href?: string;
}

const { href } = Astro.props;
const base = localeBase(Astro.currentLocale);
const t = getUi(Astro.currentLocale);
const converloopHref = href ?? `${base}/converloop`;
---

<a class="cl-card" href={converloopHref}>
	<div class="cl-card-top">
		<div class="cl-card-icon">
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12a9 9 0 1 1-3-6.7"></path><path d="M21 4v4h-4"></path></svg>
		</div>
		<div class="cl-card-meta">
			<span class="cl-card-badge">{t.home.converloopBadge}</span>
			<h3>{t.home.converloopTitle}</h3>
		</div>
	</div>
	<p class="cl-card-desc">{t.home.converloopDescription}</p>
	<span class="cl-card-cta">{t.home.converloopCta} →</span>
</a>

<style is:global>
	@import '../styles/converloop.css';
</style>
