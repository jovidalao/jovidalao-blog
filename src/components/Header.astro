---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { SITE_TITLE } from '../consts';
import { getUi, localeBase } from '../i18n';
import HeaderLink from './HeaderLink.astro';

const lang = Astro.currentLocale;
const base = localeBase(lang);
const t = getUi(lang);
const enPath = getRelativeLocaleUrl('en', Astro.url.pathname);
const zhPath = getRelativeLocaleUrl('zh', Astro.url.pathname);
---

<header>
	<nav>
		<h2><a href={base || '/'}>{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href={base || '/'}>{t.nav.home}</HeaderLink>
			<HeaderLink href={`${base}/peelday`}>{t.nav.peelday}</HeaderLink>
			<HeaderLink href={`${base}/converloop`}>{t.nav.converloop}</HeaderLink>
		</div>
		<div class="right-section">
			<div class="theme-dropdown">
				<button class="theme-btn" aria-label={t.theme.system}>
					<span class="theme-icon" data-icon="light" hidden>
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2"></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path></svg>
					</span>
					<span class="theme-icon" data-icon="dark" hidden>
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path></svg>
					</span>
					<span class="theme-icon" data-icon="system">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"></rect><line x1="8" x2="16" y1="21" y2="21"></line><line x1="12" x2="12" y1="17" y2="21"></line></svg>
					</span>
				</button>
				<div class="dropdown-content">
					<div class="dropdown-content-inner">
						<button data-theme-value="light">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2"></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path></svg>
							<span>{t.theme.light}</span>
						</button>
						<button data-theme-value="dark">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path></svg>
							<span>{t.theme.dark}</span>
						</button>
						<button data-theme-value="system">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"></rect><line x1="8" x2="16" y1="21" y2="21"></line><line x1="12" x2="12" y1="17" y2="21"></line></svg>
							<span>{t.theme.system}</span>
						</button>
					</div>
				</div>
			</div>
			<div class="lang-dropdown">
				<button class="lang-btn">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
					<span>{lang === 'zh' ? '中文' : 'English'}</span>
				</button>
				<div class="dropdown-content">
					<div class="dropdown-content-inner">
						<a href={enPath} class={lang === 'en' ? 'active' : ''}>English</a>
						<a href={zhPath} class={lang === 'zh' ? 'active' : ''}>中文</a>
					</div>
				</div>
			</div>
			<div class="social-links">
			<a href="https://x.com/jovidalao" target="_blank">
				<span class="sr-only">Follow jovidalao on X</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M12.6.75h2.454l-5.36 6.142L16 15.25h-4.937l-3.867-5.07-4.425 5.07H.316l5.733-6.57L0 .75h5.063l3.495 4.633L12.6.75Zm-.86 13.028h1.36L4.323 2.145H2.865l8.875 11.633Z"
					></path></svg
				>
			</a>
			<a href="https://github.com/jovidalao" target="_blank">
				<span class="sr-only">Go to Astro's GitHub repo</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
		</div>
	</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--surface);
		box-shadow: var(--header-shadow);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
	}
	.internal-links {
		display: flex;
		justify-content: center;
	}
	nav a {
		padding: 1em 0.5em;
		color: rgb(var(--black));
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.lang-dropdown,
	.theme-dropdown {
		position: relative;
		display: inline-block;
	}
	.lang-btn,
	.theme-btn {
		display: flex;
		align-items: center;
		gap: 0.5em;
		background: none;
		border: 1px solid var(--control-border);
		padding: 0.4em 0.8em;
		border-radius: 20px;
		cursor: pointer;
		font-size: 0.9em;
		color: rgb(var(--black));
		transition: all 0.2s;
	}
	.theme-btn {
		padding: 0.4em;
		justify-content: center;
	}
	.lang-btn:hover,
	.theme-btn:hover {
		border-color: var(--accent);
		color: var(--accent);
	}
	.theme-icon {
		display: inline-flex;
	}
	.theme-icon[hidden] {
		display: none;
	}
	.dropdown-content {
		display: none;
		position: absolute;
		right: 0;
		top: 100%;
		background-color: transparent; /* Transparent parent to hold the gap */
		min-width: 140px;
		z-index: 100;
		padding-top: 10px; /* This is the clickable 'bridge' gap */
	}
	.dropdown-content-inner {
		background-color: var(--surface);
		box-shadow: var(--popover-shadow);
		border-radius: 8px;
		overflow: hidden;
		border: 1px solid var(--surface-border);
	}
	/* Remove the old bridge */
	.lang-dropdown:hover .dropdown-content,
	.theme-dropdown:hover .dropdown-content {
		display: block;
	}
	.dropdown-content a,
	.dropdown-content button {
		color: rgb(var(--black));
		padding: 10px 16px;
		text-decoration: none;
		display: block;
		font-size: 0.9em;
		text-align: left;
		border-bottom: none !important;
	}
	.dropdown-content button {
		display: flex;
		align-items: center;
		gap: 0.6em;
		width: 100%;
		background: none;
		border: none;
		cursor: pointer;
		font-family: inherit;
	}
	.dropdown-content a:hover,
	.dropdown-content button:hover {
		background-color: var(--surface-hover);
		color: var(--accent);
	}
	.dropdown-content a.active,
	.dropdown-content button.active {
		font-weight: bold;
		color: var(--accent);
		background-color: var(--surface-active);
	}
	.right-section {
		display: flex;
		align-items: center;
		gap: 1em;
		justify-self: end;
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
<script>
	const KEY = 'theme';
	const mql = window.matchMedia('(prefers-color-scheme: dark)');
	const options = document.querySelectorAll<HTMLButtonElement>(
		'.theme-dropdown button[data-theme-value]',
	);
	const icons = document.querySelectorAll<HTMLElement>('.theme-btn .theme-icon');

	const getPref = () => localStorage.getItem(KEY) ?? 'system';
	const resolve = (pref: string) =>
		pref === 'dark' || (pref === 'system' && mql.matches) ? 'dark' : 'light';

	const apply = (pref: string) => {
		document.documentElement.dataset.theme = resolve(pref);
		icons.forEach((el) => {
			el.hidden = el.dataset.icon !== pref;
		});
		options.forEach((b) => {
			const on = b.dataset.themeValue === pref;
			b.classList.toggle('active', on);
			b.setAttribute('aria-pressed', String(on));
		});
	};

	options.forEach((b) => {
		b.addEventListener('click', () => {
			const value = b.dataset.themeValue;
			if (!value) return;
			localStorage.setItem(KEY, value);
			apply(value);
		});
	});

	apply(getPref());
	mql.addEventListener('change', () => {
		if (getPref() === 'system') apply('system');
	});
</script>
