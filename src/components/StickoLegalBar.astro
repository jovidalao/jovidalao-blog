---
import { STICKO } from '../consts';
import { getUi, localeBase } from '../i18n';

const base = localeBase(Astro.currentLocale);
const t = getUi(Astro.currentLocale);
const stickoBase = `${base}/sticko`;
---

<nav class="sticko-legal-bar" aria-label="Legal">
	<a href={`${stickoBase}/privacy`}>{t.sticko.legal.privacy}</a>
	<a href={`${stickoBase}/terms`}>{t.sticko.legal.terms}</a>
	<a href={`mailto:${STICKO.contactEmail}`}>{t.sticko.legal.contact}</a>
</nav>
